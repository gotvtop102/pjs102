g An Như Cố\\\".</p>","tmdb_id":130107,"cast":["Nhậm Gia Luân","Bạch Lộc","Thử Sa","Lạc Minh Cật","Wang Ruixin","Jin Liting","Gao Xuyang","Liu Ruogu","Ai Jiani","Luo Haiqiong"],"director":["Shen Yang","Ben Fang"],"keywords":[],"cast_meta":[{"name":"Nhậm Gia Luân","name_vi":"Nhậm Gia Luân","name_original":"Ren Jialun","tmdb_id":2084465,"profile":"https://image.tmdb.org/t/p/w500/5sBfnbHbTmNriFPGGD12mPpTNNO.jpg","tmdb_url":"https://www.themoviedb.org/person/2084465"},{"name":"Bạch Lộc","name_vi":"Bạch Lộc","name_original":"Bai Lu","tmdb_id":1879666,"profile":"https://image.tmdb.org/t/p/w500/aRcUVDRO2wewQe0NXJ0RfzSgvUa.jpg","tmdb_url":"https://www.themoviedb.org/person/1879666"},{"name":"Thử Sa","name_vi":"Thử Sa","name_original":"Ci Sha","tmdb_id":3167855,"profile":"https://image.tmdb.org/t/p/w500/eWytg5M0VUCb0aHEKpUDijQ7JxF.jpg","tmdb_url":"https://www.themoviedb.org/person/3167855"},{"name":"Lạc Minh Cật","name_vi":"Lạc Minh Cật","name_original":"Luo Mingjie","tmdb_id":2359338,"profile":"https://image.tmdb.org/t/p/w500/cg8cgZXDBeRdW50yFpRr5zhCUpJ.jpg","tmdb_url":"https://www.themoviedb.org/person/2359338"},{"name":"Wang Ruixin","name_vi":null,"name_original":"Wang Ruixin","tmdb_id":3177467,"profile":"https://image.tmdb.org/t/p/w500/gcxL2XaoPgwUiLl1Uosz7dtkKjP.jpg","tmdb_url":"https://www.themoviedb.org/person/3177467"},{"name":"Jin Liting","name_vi":null,"name_original":"Jin Liting","tmdb_id":2997391,"profile":"https://image.tmdb.org/t/p/w500/fNzKhO7XjpayVBiQRStmk65Ov6c.jpg","tmdb_url":"https://www.themoviedb.org/person/2997391"},{"name":"Gao Xuyang","name_vi":null,"name_original":"Gao Xuyang","tmdb_id":2823732,"profile":"https://image.tmdb.org/t/p/w500/tl991NePiangXwZGsnwcILQFtAE.jpg","tmdb_url":"https://www.themoviedb.org/person/2823732"},{"name":"Liu Ruogu","name_vi":null,"name_original":"Liu Ruogu","tmdb_id":2747081,"profile":"https://image.tmdb.org/t/p/w500/bCaAQDixboeq8Ss3BIkfASGeC1g.jpg","tmdb_url":"https://www.themoviedb.org/person/2747081"},{"name":"Ai Jiani