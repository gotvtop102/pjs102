re/d7cbbf830501a1332d11174fd90af4db","link_m3u8":"https://vip.opstream15.com/20230330/37063_703e616c/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream15.com/share/59cc91f50641f69e21221695aa6a8bd1","link_m3u8":"https://vip.opstream15.com/20230330/37066_2c78d9d1/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream15.com/share/9987439b9205fa1e757a7d32cc51777f","link_m3u8":"https://vip.opstream15.com/20230330/37069_fbb46f1e/index.m3u8"}]}],"description":"<p>Trải qua nhiều lần thất bại, Eo Su Seon giỏi giang, xinh đẹp, lạc quan cuối cùng cũng đã vượt qua kỳ thi cảnh sát viên chức, trở thành cảnh sát hình sự của Sở cảnh sát Giang Nam như mong muốn, cô ấy cùng với ba người khác bao gồm: Eun Dae Gu- người vô cùng căm thù, Park Tae Il- người luôn phát ra một khí chất quý tộc và Ji Guk- một tên gian xảo, mánh khoé không có tham vọng được phân vào đội số 3 do Seo Pan Seok làm đội trưởng. Đội trưởng Seo Pan Seok oai phong, anh dũng, là một cảnh sát hình sự xuất chúng, lập được nhiều chiến tích, song bốn người mới với tính cách hoàn toàn trái ngược nhau và gây ra không ít phiền phức này thực sự là làm khó cho anh ấy, bốn người không những liên tục gây chuyện, mà còn phá hỏng hành động của các phòng ban khác. Dù vậy, đội trưởng Seo Pan Seok vẫn quyết tâm dùng thời gian ba tháng để huấn luyện bọn họ.</p>","tmdb_id":61173,"cast":[],"director":[],"keywords":[],"tmdb":{"id":61173},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/ch/chay-dau-cho-thoat-phim-bo.json"}