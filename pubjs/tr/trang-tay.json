vip.opstream14.com/20230301/33179_67c1e035/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream14.com/share/41ac67fc0943e6d7fd4fc607cb65c45e","link_m3u8":"https://vip.opstream14.com/20230301/33180_18cab7db/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream14.com/share/843885e08f45a17acdb9d508bce80275","link_m3u8":"https://vip.opstream14.com/20230301/33181_4f2a030a/index.m3u8"}]}],"description":"<p>TRẮNG TAY Back to Square One xoay quanh những đợt khủng hoảng tài chính toàn cầu đã khiến cho rất nhiều gia đình lâm vào cảnh khốn đốn. Trong số đó có đôi vợ chồng mẫu mực – Thường Hạo Thâm (do Ngô Khải Hoa đóng) và Ân Thiện Mỹ (do Diệp Đồng đóng).Cặp đôi Thâm – Mỹ vốn được người người ngưỡng mộ. Chồng chăm chỉ làm ăn, ôn hòa và chung thủy. Vợ xinh đẹp, khôn ngoan. Con cái lanh lợi, hoạt bát. Bề ngoài họ vẫn vui vẻ với mọi người, nhưng thực chất trong thâm tâm đang ngập tràn bão tố. Mỹ ham hưởng thụ, chuộng vật chất. Cô quyết tâm không để việc làm ăn của hai vợ chồng phá sản.</p>","tmdb_id":108245,"cast":[],"director":[],"keywords":[],"tmdb":{"id":108245},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/tr/trang-tay.json"}