n thứ hai được phát sóng vào Chủ nhật lúc 9:00 tối tại Hoa Kỳ. Phần cuối của mùa được phát sóng vào ngày 13 tháng 9 năm 2009.</p>","tmdb_id":10545,"cast":[],"director":[],"keywords":[],"tmdb":{"id":10545},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/thuan-huyet-phan-2.json"}