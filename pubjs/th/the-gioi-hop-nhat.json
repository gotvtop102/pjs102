c67c5dc87","link_m3u8":"https://vip.opstream14.com/20230302/33219_2ce471cc/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream14.com/share/2a11da4581b3801a09326efe6cf2af23","link_m3u8":"https://vip.opstream14.com/20230302/33220_d5ad38e3/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream14.com/share/4dc8561bc064ecf48381d76e16c143ba","link_m3u8":"https://vip.opstream14.com/20230302/33221_cd8b9859/index.m3u8"}]}],"description":"<p>Phim kể về câu chuyện về hai người bạn thời thơ ấu Hae Sung (Yeo Jin Goo đóng) và Jung Won (Lee Yeon Hee đóng) mặc dù sinh cùng năm nhưng vì một lí do kỳ lạ mà họ gặp lại với ngoại hình hoàn toàn chênh lệch. Hae Sung gặp tai nạn qua đời khi mới học trung học. 12 năm sau anh đột ngột xuất hiện với vẻ ngoài và tính cách y như khi 19 tuổi trong khi cô bạn thân Jung Won của anh đã 31 tuổi. Mối quan hệ mới của họ bắt đầu mở ra từ đây. Bên cạnh đó, Cha Min Joon (Ahn Jae Hyun đóng), đầu bếp của nhà hàng nơi Jung Won đang làm việc cũng đang thầm thích cô.</p>","tmdb_id":72549,"cast":[],"director":[],"keywords":[],"tmdb":{"id":72549},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/th/the-gioi-hop-nhat.json"}