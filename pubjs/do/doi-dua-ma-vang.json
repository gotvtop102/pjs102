e1f2","link_m3u8":"https://vip.opstream14.com/20230216/31799_7ed97403/index.m3u8"},{"name":"19","slug":"19","link_embed":"https://vip.opstream14.com/share/907426606e10139de6617963c3e73cff","link_m3u8":"https://vip.opstream14.com/20230216/31800_cc1f5799/index.m3u8"},{"name":"20","slug":"20","link_embed":"https://vip.opstream14.com/share/7dcf8773e0db912ac8a9bd8914aed99e","link_m3u8":"https://vip.opstream14.com/20230216/31801_71debd5e/index.m3u8"},{"name":"21","slug":"21","link_embed":"https://vip.opstream14.com/share/a306a13c6c1ee387390fdc96c7bdca66","link_m3u8":"https://vip.opstream14.com/20230216/31802_249388df/index.m3u8"},{"name":"22","slug":"22","link_embed":"https://vip.opstream14.com/share/922a7fd3b1c537453af87329140dcfb2","link_m3u8":"https://vip.opstream14.com/20230216/31803_589fbd91/index.m3u8"},{"name":"23","slug":"23","link_embed":"https://vip.opstream14.com/share/70e57e78fd611128e6e6212c59c28b59","link_m3u8":"https://vip.opstream14.com/20230216/31804_e5390f71/index.m3u8"},{"name":"24","slug":"24","link_embed":"https://vip.opstream14.com/share/a4cfa38878b278bbe2f6f5172474f86b","link_m3u8":"https://vip.opstream14.com/20230216/31805_6247a381/index.m3u8"},{"name":"25","slug":"25","link_embed":"https://vip.opstream14.com/share/d89920adb1af2d681ea0df8a9f863a82","link_m3u8":"https://vip.opstream14.com/20230216/31806_85ea81a4/index.m3u8"}]}],"description":"<p>Nội dung phim xoay quanh cuộc đời của anh chàng Cao Thiên Bảo. Xuất thân trong một gia đình giàu có, Thiên Bảo được lớn lên trong nhung lụa, sự yêu thương và đùm bọc. Sớm bộc lộ tài năng ẩm thực, cùng điều kiện tốt, cậu biết được nhiều món ăn ngon và quý.Tuy nhiên, sóng gió vô tình ập đến với gia đình khiến Thiên Bảo phải bỏ trốn cùng người hầu thân cận, sống phiêu bạt thiên hạ, kiếm ăn qua ngày.Nhờ tài nấu nướng, cậu mới có thể vượt qua những ngày tháng khó khăn và kết giao được với nhiều người bạn mới, trong đó có hoàng thượng Dân Chân trong một lần vi hành. Hai người mới gặp như đã quen từ lâu, hoàng thượng quyết mời Thiên Bảo vào cung làm ngự trù. Chưa được bao lâu thì liên tiếp những xích mích xảy ra, Thiên Bảo bị cuốn theo cuộc chiến hoàng tộc.</p>","tmdb_id":88389,"cast":[],"director":[],"keywords":[],"tmdb":{"id":88389},"cast_meta":[],"tmdb_checked":false,"pubjs_url":"https://cdn.jsdelivr.net/gh/gotvtop102/pjs102@main/pubjs/do/doi-dua-ma-vang.json"}